{
  "name": "@fullstackcraftllc/youtube-mcp",
  "version": "0.1.0",
  "description": "A safe, local-first MCP server for managing and analyzing your YouTube channel.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "youtube-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "server.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "build": "npm run clean && tsc -p tsconfig.json && node scripts/make-executable.mjs",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "verify-package": "node scripts/verify-package.mjs",
    "smoke:packed": "node scripts/smoke-packed.mjs",
    "secret-scan": "node scripts/secret-scan.mjs",
    "audit:runtime": "npm audit --omit=dev --audit-level=high",
    "release:check": "npm run type-check && npm test && npm run build && npm run verify-package && npm run smoke:packed && npm run secret-scan && npm run audit:runtime"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FullStackCraft/youtube-mcp.git"
  },
  "homepage": "https://github.com/FullStackCraft/youtube-mcp#readme",
  "bugs": {
    "url": "https://github.com/FullStackCraft/youtube-mcp/issues"
  },
  "keywords": [
    "youtube",
    "mcp",
    "model-context-protocol",
    "analytics",
    "creator-tools"
  ],
  "author": "Full Stack Craft LLC",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@googleapis/youtube": "^33.0.0",
    "@googleapis/youtubeanalytics": "^6.0.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "env-paths": "^4.0.0",
    "google-auth-library": "10.5.0",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
